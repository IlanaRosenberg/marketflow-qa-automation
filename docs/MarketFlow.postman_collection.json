{
  "info": {
    "name": "MarketFlow API",
    "description": "Complete API collection for MarketFlow QA Automation Portfolio Project.\n\n**Setup:**\n1. Import this collection and the `MarketFlow.postman_environment.json` environment\n2. Select the `MarketFlow Local` environment\n3. Run `python run.py` to start the server\n4. Execute **Auth > Login** first — the token is auto-saved to `{{token}}`\n\n**Seed credentials:**\n- testuser1@example.com / Password123!\n- testuser2@example.com / Password123!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password123!\",\n  \"first_name\": \"New\",\n  \"last_name\": \"User\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success && res.data.token) {",
                "  pm.environment.set('token', res.data.token);",
                "  console.log('Token saved to environment');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser1@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login — Wrong Password (Negative)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser1@example.com\",\n  \"password\": \"WrongPassword!\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/?page=1&per_page=10", "host": ["{{base_url}}"], "path": ["api","products",""], "query": [{"key":"page","value":"1"},{"key":"per_page","value":"10"}] }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/?search=Laptop", "host": ["{{base_url}}"], "path": ["api","products",""], "query": [{"key":"search","value":"Laptop"}] }
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/?category=Sports", "host": ["{{base_url}}"], "path": ["api","products",""], "query": [{"key":"category","value":"Sports"}] }
          }
        },
        {
          "name": "Sort by Price",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/?sort=price", "host": ["{{base_url}}"], "path": ["api","products",""], "query": [{"key":"sort","value":"price"}] }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["api","products","{{product_id}}"] }
          }
        },
        {
          "name": "Get Out-of-Stock Product (ID=3)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/3", "host": ["{{base_url}}"], "path": ["api","products","3"] }
          }
        },
        {
          "name": "Get Product Not Found (Negative)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products/99999", "host": ["{{base_url}}"], "path": ["api","products","99999"] }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/products/", "host": ["{{base_url}}"], "path": ["api","products",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Test Product\",\n  \"description\": \"Created via Postman\",\n  \"price\": 19.99,\n  \"stock_quantity\": 10,\n  \"sku\": \"POSTMAN-001\",\n  \"category\": \"Electronics\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/", "host": ["{{base_url}}"], "path": ["api","cart",""] }
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/add", "host": ["{{base_url}}"], "path": ["api","cart","add"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Add Out-of-Stock Product (Negative)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/add", "host": ["{{base_url}}"], "path": ["api","cart","add"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 3,\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/item/1", "host": ["{{base_url}}"], "path": ["api","cart","item","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/item/1", "host": ["{{base_url}}"], "path": ["api","cart","item","1"] }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cart/clear", "host": ["{{base_url}}"], "path": ["api","cart","clear"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success && res.data.id) {",
                "  pm.environment.set('order_id', res.data.id);",
                "  console.log('Order ID saved:', res.data.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/checkout", "host": ["{{base_url}}"], "path": ["api","orders","checkout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"credit_card\"\n}"
            }
          }
        },
        {
          "name": "Checkout — Empty Cart (Negative)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/checkout", "host": ["{{base_url}}"], "path": ["api","orders","checkout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"credit_card\"\n}"
            }
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/", "host": ["{{base_url}}"], "path": ["api","orders",""] }
          }
        },
        {
          "name": "Filter Orders by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/?status=completed", "host": ["{{base_url}}"], "path": ["api","orders",""], "query": [{"key":"status","value":"completed"}] }
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["api","orders","{{order_id}}"] }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}/cancel", "host": ["{{base_url}}"], "path": ["api","orders","{{order_id}}","cancel"] }
          }
        },
        {
          "name": "Cancel Already-Completed Order (Negative)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}/cancel", "host": ["{{base_url}}"], "path": ["api","orders","{{order_id}}","cancel"] }
          }
        }
      ]
    }
  ]
}
